// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

/// @ts-nocheck
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  oasisBios     OasisBio[]
  profiles      Profile[]
  exportHistory ExportHistory[]

  @@index([createdAt])
  @@index([email])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  username        String   @unique
  displayName     String   @map("display_name")
  avatarUrl       String?  @map("avatar_url")
  bio             String?
  website         String?
  locale          String   @default("en")
  defaultLanguage String   @default("en") @map("default_language")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([username])
  @@index([createdAt])
  @@map("profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OasisBio {
  id              String                  @id @default(cuid())
  userId          String                  @map("user_id")
  title           String
  slug            String                  @unique
  tagline         String?
  summary         String?
  identityMode    String                  @default("real")
  birthDate       DateTime?
  gender          String?
  pronouns        String?
  placeOfOrigin   String?                 @map("origin_place")
  currentEra      String?
  species         String?
  status          String                  @default("draft")
  description     String?
  coverImageUrl   String?                 @map("cover_image_url")
  defaultLanguage String                  @default("en") @map("default_language")
  visibility      String                  @default("private")
  featured        Boolean                 @default(false)
  publishedAt     DateTime?               @map("published_at")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  abilities       Ability[]
  dcosFiles       DcosFile[]
  references      ReferenceItem[]
  worlds          WorldItem[]
  models          ModelItem[]
  eras            EraIdentity[]
  publication     OasisBioPublication?
  relationshipsA  CharacterRelationship[] @relation("CharacterARelationship")
  relationshipsB  CharacterRelationship[] @relation("CharacterBRelationship")

  @@index([userId])
  @@index([slug])
  @@index([visibility])
  @@index([featured])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([publishedAt])
  @@map("oasis_bios")
}

model EraIdentity {
  id          String    @id @default(cuid())
  oasisBioId  String    @map("oasis_bio_id")
  name        String
  eraType     String
  startYear   Int?      @map("start_year")
  endYear     Int?      @map("end_year")
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  oasisBio    OasisBio  @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)
  abilities   Ability[]
  dcosFiles   DcosFile[]
  references  ReferenceItem[]

  @@index([oasisBioId])
  @@index([sortOrder])
  @@map("era_identities")
}

model Ability {
  id             String       @id @default(cuid())
  oasisBioId     String       @map("oasis_bio_id")
  name           String
  category       String
  sourceType     String       @default("custom") @map("source_type")
  level          Int          @default(1)
  description    String?
  relatedWorldId String?      @map("related_world_id")
  relatedEraId   String?      @map("related_era_id")
  oasisBio       OasisBio     @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)
  relatedWorld   WorldItem?   @relation(fields: [relatedWorldId], references: [id], onDelete: SetNull)
  relatedEra     EraIdentity? @relation(fields: [relatedEraId], references: [id], onDelete: SetNull)

  @@index([oasisBioId])
  @@index([category])
  @@index([level])
  @@index([relatedWorldId])
  @@index([relatedEraId])
  @@map("abilities")
}

model DcosFile {
  id         String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  title      String
  slug       String   @unique
  content    String
  folderPath String   @map("folder_path")
  status     String   @default("draft")
  version    Int      @default(1)
  eraId      String?  @map("era_id")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  oasisBio   OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)
  era        EraIdentity? @relation(fields: [eraId], references: [id], onDelete: SetNull)

  @@index([oasisBioId])
  @@index([slug])
  @@index([status])
  @@index([eraId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("dcos_files")
}

model ReferenceItem {
  id          String   @id @default(cuid())
  oasisBioId  String   @map("oasis_bio_id")
  url         String
  title       String
  description String?
  sourceType  String   @map("source_type")
  provider    String?
  coverImage  String?  @map("cover_image")
  metadata    String?
  eraId       String?  @map("era_id")
  worldId     String?  @map("world_id")
  tags        String
  oasisBio    OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)
  era         EraIdentity? @relation(fields: [eraId], references: [id], onDelete: SetNull)
  world       WorldItem? @relation(fields: [worldId], references: [id], onDelete: SetNull)

  @@index([oasisBioId])
  @@index([sourceType])
  @@index([eraId])
  @@index([worldId])
  @@index([tags])
  @@map("reference_items")
}

model WorldItem {
  id                String          @id @default(cuid())
  oasisBioId        String          @map("oasis_bio_id")
  name              String
  summary           String
  timeSetting       String?         @map("time_setting")
  geography         String?
  physicsRules      String?         @map("physics_rules")
  socialStructure   String?         @map("social_structure")
  aestheticKeywords String?         @map("aesthetic_keywords")
  majorConflict     String?         @map("major_conflict")
  visibility        String          @default("private")
  timeline          String?
  rules             String?
  factions          String?
  oasisBio          OasisBio        @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)
  documents         WorldDocument[]
  abilities         Ability[]
  references        ReferenceItem[]

  @@index([oasisBioId])
  @@index([visibility])
  @@map("world_items")
}

model ModelItem {
  id             String   @id @default(cuid())
  oasisBioId     String   @map("oasis_bio_id")
  name           String   @map("model_name")
  filePath       String   @map("file_path")
  modelFormat    String   @default("glb") @map("model_format")
  previewImage   String?  @map("preview_image")
  relatedWorldId String?
  relatedEraId   String?
  isPrimary      Boolean  @default(false) @map("is_primary")
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  oasisBio       OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@index([oasisBioId])
  @@index([isPrimary])
  @@index([modelFormat])
  @@index([createdAt])
  @@map("model_items")
}

model AbilityCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  slug        String          @unique
  description String?
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  presets     AbilityPreset[]

  @@map("ability_categories")
}

model AbilityPreset {
  id          String           @id @default(cuid())
  categoryId  String?          @map("category_id")
  name        String
  slug        String           @unique
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  category    AbilityCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("ability_presets")
}

model WorldDocument {
  id         String    @id @default(cuid())
  worldId    String    @map("world_id")
  title      String
  docType    String    @map("doc_type")
  slug       String
  content    String
  folderPath String    @default("/") @map("folder_path")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  world      WorldItem @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@index([docType])
  @@index([slug])
  @@index([folderPath])
  @@index([sortOrder])
  @@map("world_documents")
}

model OasisBioPublication {
  id             String    @id @default(cuid())
  oasisBioId     String    @unique @map("oasis_bio_id")
  publicSlug     String    @unique @map("public_slug")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  socialImageUrl String?   @map("social_image_url")
  customDomain   String?   @map("custom_domain")
  isSearchable   Boolean   @default(true) @map("is_searchable")
  publishedAt    DateTime? @map("published_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  oasisBio       OasisBio  @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("oasisbio_publications")
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  slug       String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  entityTags EntityTag[]

  @@map("tags")
}

model EntityTag {
  id         String   @id @default(cuid())
  tagId      String   @map("tag_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("entity_tags")
}

model CharacterRelationship {
  id           String   @id @default(cuid())
  characterAId String   @map("character_a_id")
  characterBId String   @map("character_b_id")
  relationType String   @map("relation_type")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  characterA   OasisBio @relation("CharacterARelationship", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB   OasisBio @relation("CharacterBRelationship", fields: [characterBId], references: [id], onDelete: Cascade)

  @@map("character_relationships")
}

model ExportHistory {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  fileName       String   @map("file_name")
  fileSize       Int      @map("file_size")
  characterCount Int      @map("character_count")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("export_history")
}

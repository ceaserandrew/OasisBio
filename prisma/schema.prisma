// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:Ihatevex@123@db.dhkgfdllgtmbkwcbubqt.supabase.co:5432/postgres"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  oasisBios     OasisBio[]
  profiles      Profile[]
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  username          String    @unique
  displayName       String    @map("display_name")
  avatarUrl         String?   @map("avatar_url")
  bio               String?
  website           String?
  locale            String    @default("en")
  defaultLanguage   String    @default("en") @map("default_language")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OasisBio {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  title         String
  slug          String        @unique
  tagline       String?
  summary       String?
  identityMode  String        @default("real")
  birthDate     DateTime?
  gender        String?
  pronouns      String?
  placeOfOrigin String?
  currentEra    String?
  species       String?
  status        String        @default("draft")
  description   String?
  coverImageUrl String?       @map("cover_image_url")
  defaultLanguage String      @default("en") @map("default_language")
  visibility    String        @default("private")
  featured      Boolean       @default(false)
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  abilities     Ability[]
  dcosFiles     DcosFile[]
  references    ReferenceItem[]
  worlds        WorldItem[]
  models        ModelItem[]
  eras          EraIdentity[]
  publication   OasisBioPublication?
  relationshipsA CharacterRelationship[] @relation("CharacterARelationship")
  relationshipsB CharacterRelationship[] @relation("CharacterBRelationship")

  @@map("oasis_bios")
}

model EraIdentity {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  name      String
  eraType   String
  startDate DateTime?
  endDate   DateTime?
  description String?
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("era_identities")
}

model Ability {
  id            String    @id @default(cuid())
  oasisBioId    String    @map("oasis_bio_id")
  name          String
  category      String
  type          String    @default("custom")
  level         Int       @default(1)
  description   String?
  relatedWorldId String?
  relatedEraId  String?
  oasisBio      OasisBio  @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("abilities")
}

model DcosFile {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  title     String
  content   String
  folder    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("dcos_files")
}

model ReferenceItem {
  id          String   @id @default(cuid())
  oasisBioId  String   @map("oasis_bio_id")
  url         String
  title       String
  type        String
  description String?
  tags        String
  oasisBio    OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("reference_items")
}

model WorldItem {
  id        String   @id @default(cuid())
  oasisBioId String   @map("oasis_bio_id")
  name      String
  summary   String
  timeline  String?
  rules     String?
  factions  String?
  oasisBio  OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("world_items")
}

model ModelItem {
  id            String   @id @default(cuid())
  oasisBioId    String   @map("oasis_bio_id")
  name          String
  objUrl        String
  mtlUrl        String?
  previewImage  String?
  relatedWorldId String?
  relatedEraId  String?
  isPrimary     Boolean  @default(false) @map("is_primary")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  oasisBio      OasisBio @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("model_items")
}

model AbilityCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  presets     AbilityPreset[]

  @@map("ability_categories")
}

model AbilityPreset {
  id         String         @id @default(cuid())
  categoryId String?        @map("category_id")
  name       String
  slug       String         @unique
  description String?
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  category   AbilityCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("ability_presets")
}

model WorldDocument {
  id          String    @id @default(cuid())
  worldId     String    @map("world_id")
  title       String
  docType     String    @map("doc_type")
  slug        String
  content     String
  folderPath  String    @default("/") @map("folder_path")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  world       WorldItem @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("world_documents")
}

model OasisBioPublication {
  id             String    @id @default(cuid())
  oasisBioId     String    @unique @map("oasis_bio_id")
  publicSlug     String    @unique @map("public_slug")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  socialImageUrl String?   @map("social_image_url")
  customDomain   String?   @map("custom_domain")
  isSearchable   Boolean   @default(true) @map("is_searchable")
  publishedAt    DateTime? @map("published_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  oasisBio       OasisBio  @relation(fields: [oasisBioId], references: [id], onDelete: Cascade)

  @@map("oasisbio_publications")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  createdAt DateTime    @default(now()) @map("created_at")
  entityTags EntityTag[]

  @@map("tags")
}

model EntityTag {
  id         String   @id @default(cuid())
  tagId      String   @map("tag_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("entity_tags")
}

model CharacterRelationship {
  id           String    @id @default(cuid())
  characterAId String    @map("character_a_id")
  characterBId String    @map("character_b_id")
  relationType String    @map("relation_type")
  description  String?
  createdAt    DateTime  @default(now()) @map("created_at")
  characterA   OasisBio  @relation("CharacterARelationship", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB   OasisBio  @relation("CharacterBRelationship", fields: [characterBId], references: [id], onDelete: Cascade)

  @@map("character_relationships")
}

